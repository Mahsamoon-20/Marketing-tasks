function renderCards(data) {
  const grid = document.getElementById('grid');
  grid.innerHTML = '';
  data.forEach((s, i) => {
    const card = document.createElement('div');
    card.className = 'card';
    card.dataset.cat = s.category;
    card.style.animationDelay = (i * 0.05) + 's';

    card.innerHTML = `
      <div class="card-header" onclick="toggleCard(this)">
        <div class="card-icon">${s.icon}</div>
        <div class="card-meta">
          <div class="card-category">${s.category.toUpperCase()}</div>
          <div class="card-title">${s.title}</div>
          <div class="card-price">${s.price}</div>
        </div>
        <div class="toggle-icon">▾</div>
      </div>
      <div class="progress-wrap">
        <div class="progress-bar"><div class="progress-fill" style="width:0%"></div></div>
        <div class="progress-label">0 / ${s.steps.length} steps</div>
      </div>
      <div class="steps">
        ${s.steps.map((step, idx) => `
          <div class="step" style="animation-delay:${idx * 0.04}s">
            <div class="step-num">${idx + 1}</div>
            <div class="step-content">
              <div class="step-title">${step.title}</div>
              <div class="step-desc">${step.desc}</div>
            </div>
          </div>
        `).join('')}
      </div>
    `;
    grid.appendChild(card);
  });
}

function toggleCard(header) {
  const card = header.closest('.card');
  card.classList.toggle('open');
}

function filter(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const filtered = cat === 'all' ? services : services.filter(s => s.category === cat);
  renderCards(filtered);
}

function expandAll() {
  const cards = document.querySelectorAll('.card');
  const allOpen = [...cards].every(c => c.classList.contains('open'));
  cards.forEach(c => allOpen ? c.classList.remove('open') : c.classList.add('open'));
  document.querySelector('.expand-all').textContent = allOpen ? 'Expand All' : 'Collapse All';
}

renderCards(services);
